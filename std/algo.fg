# std.algo — sorting, searching, and common algorithms
#
# Pure Forge implementations of fundamental algorithms.
# All functions return new lists — inputs are never modified.
#
#   from std.algo import sort, sort_desc, binary_search, unique, zip
#   sorted := sort([3, 1, 4, 1, 5])       # [1, 1, 3, 4, 5]
#   idx := binary_search(sorted, 4)        # 3
#   deduped := unique([1, 2, 2, 3, 3, 3]) # [1, 2, 3]

# ===============================================================
# Sorting
# ===============================================================

# Sorts a list of integers in ascending order (merge sort, stable)
pub fn sort(list: List[Int]) -> List[Int]:
    n := list.len()
    if n <= 1:
        return list
    mid := n / 2
    mut left: List[Int] := []
    mut right: List[Int] := []
    mut i := 0
    while i < mid:
        left.push(list[i])
        i = i + 1
    while i < n:
        right.push(list[i])
        i = i + 1
    left = sort(left)
    right = sort(right)
    return merge(left, right)

fn merge(a: List[Int], b: List[Int]) -> List[Int]:
    mut result: List[Int] := []
    mut i := 0
    mut j := 0
    while i < a.len() and j < b.len():
        if a[i] <= b[j]:
            result.push(a[i])
            i = i + 1
        else:
            result.push(b[j])
            j = j + 1
    while i < a.len():
        result.push(a[i])
        i = i + 1
    while j < b.len():
        result.push(b[j])
        j = j + 1
    return result

# Sorts a list of integers in descending order
pub fn sort_desc(list: List[Int]) -> List[Int]:
    mut sorted := sort(list)
    return reverse_list(sorted)

# Compares two strings lexicographically. Returns -1, 0, or 1.
pub fn strcmp(a: String, b: String) -> Int:
    mut i := 0
    mut min_len := a.len()
    if b.len() < min_len:
        min_len = b.len()
    while i < min_len:
        ca := ord(a[i])
        cb := ord(b[i])
        if ca < cb:
            return -1
        if ca > cb:
            return 1
        i = i + 1
    if a.len() < b.len():
        return -1
    if a.len() > b.len():
        return 1
    return 0

# Sorts a list of strings in lexicographic order (merge sort, stable)
pub fn sort_strings(list: List[String]) -> List[String]:
    n := list.len()
    if n <= 1:
        return list
    mid := n / 2
    mut left: List[String] := []
    mut right: List[String] := []
    mut i := 0
    while i < mid:
        left.push(list[i])
        i = i + 1
    while i < n:
        right.push(list[i])
        i = i + 1
    left = sort_strings(left)
    right = sort_strings(right)
    return merge_strings(left, right)

fn merge_strings(a: List[String], b: List[String]) -> List[String]:
    mut result: List[String] := []
    mut i := 0
    mut j := 0
    while i < a.len() and j < b.len():
        if strcmp(a[i], b[j]) <= 0:
            result.push(a[i])
            i = i + 1
        else:
            result.push(b[j])
            j = j + 1
    while i < a.len():
        result.push(a[i])
        i = i + 1
    while j < b.len():
        result.push(b[j])
        j = j + 1
    return result

# ===============================================================
# Searching
# ===============================================================

# Binary search on a sorted list. Returns index of value, or -1 if not found.
pub fn binary_search(list: List[Int], value: Int) -> Int:
    mut lo := 0
    mut hi := list.len() - 1
    while lo <= hi:
        mid := lo + (hi - lo) / 2
        if list[mid] == value:
            return mid
        elif list[mid] < value:
            lo = mid + 1
        else:
            hi = mid - 1
    return -1

# Linear search. Returns index of first occurrence, or -1 if not found.
pub fn index_of(list: List[Int], value: Int) -> Int:
    mut i := 0
    while i < list.len():
        if list[i] == value:
            return i
        i = i + 1
    return -1

# Returns true if value is in the list
pub fn contains(list: List[Int], value: Int) -> Bool:
    return index_of(list, value) >= 0

# ===============================================================
# Deduplication and Filtering
# ===============================================================

# Returns a list with consecutive duplicates removed
# Input should be sorted for full deduplication
pub fn unique(list: List[Int]) -> List[Int]:
    if list.len() == 0:
        return []
    mut result: List[Int] := []
    result.push(list[0])
    mut i := 1
    while i < list.len():
        if list[i] != list[i - 1]:
            result.push(list[i])
        i = i + 1
    return result

# Removes all occurrences of a value from the list
pub fn remove_all(list: List[Int], value: Int) -> List[Int]:
    mut result: List[Int] := []
    mut i := 0
    while i < list.len():
        if list[i] != value:
            result.push(list[i])
        i = i + 1
    return result

# Returns elements that appear in both lists (preserves order from first list)
pub fn intersection(a: List[Int], b: List[Int]) -> List[Int]:
    mut result: List[Int] := []
    mut i := 0
    while i < a.len():
        mut found := false
        mut j := 0
        while j < b.len():
            if a[i] == b[j]:
                found = true
                j = b.len()
            j = j + 1
        if found:
            result.push(a[i])
        i = i + 1
    return result

# Returns elements in first list that are not in second list
pub fn difference(a: List[Int], b: List[Int]) -> List[Int]:
    mut result: List[Int] := []
    mut i := 0
    while i < a.len():
        mut found := false
        mut j := 0
        while j < b.len():
            if a[i] == b[j]:
                found = true
                j = b.len()
            j = j + 1
        if not found:
            result.push(a[i])
        i = i + 1
    return result

# ===============================================================
# List Transformation
# ===============================================================

# Reverses a list of integers
pub fn reverse_list(list: List[Int]) -> List[Int]:
    mut result: List[Int] := []
    mut i := list.len() - 1
    while i >= 0:
        result.push(list[i])
        i = i - 1
    return result

# Returns a slice of the list from start (inclusive) to end (exclusive)
pub fn slice(list: List[Int], start: Int, end: Int) -> List[Int]:
    mut result: List[Int] := []
    mut lo := start
    if lo < 0:
        lo = 0
    mut hi := end
    if hi > list.len():
        hi = list.len()
    mut i := lo
    while i < hi:
        result.push(list[i])
        i = i + 1
    return result

# Interleaves two lists: [a0, b0, a1, b1, ...]
# If lists differ in length, remaining elements are appended
pub fn zip_merge(a: List[Int], b: List[Int]) -> List[Int]:
    mut result: List[Int] := []
    mut i := 0
    mut max_len := a.len()
    if b.len() > max_len:
        max_len = b.len()
    while i < max_len:
        if i < a.len():
            result.push(a[i])
        if i < b.len():
            result.push(b[i])
        i = i + 1
    return result

# Flattens a list of lists into a single list
pub fn flatten(lists: List[List[Int]]) -> List[Int]:
    mut result: List[Int] := []
    mut i := 0
    while i < lists.len():
        inner := lists[i]
        mut j := 0
        while j < inner.len():
            result.push(inner[j])
            j = j + 1
        i = i + 1
    return result

# Splits a list into chunks of the given size
pub fn chunks(list: List[Int], size: Int) -> List[List[Int]]:
    mut result: List[List[Int]] := []
    if size <= 0:
        return result
    mut i := 0
    while i < list.len():
        mut chunk: List[Int] := []
        mut j := 0
        while j < size and i + j < list.len():
            chunk.push(list[i + j])
            j = j + 1
        result.push(chunk)
        i = i + size
    return result

# ===============================================================
# Aggregation
# ===============================================================

# Returns the sum of all elements
pub fn sum(list: List[Int]) -> Int:
    mut total := 0
    mut i := 0
    while i < list.len():
        total = total + list[i]
        i = i + 1
    return total

# Returns the product of all elements (1 for empty list)
pub fn product(list: List[Int]) -> Int:
    if list.len() == 0:
        return 1
    mut result := 1
    mut i := 0
    while i < list.len():
        result = result * list[i]
        i = i + 1
    return result

# Returns the minimum value, or 0 for empty list
pub fn min_val(list: List[Int]) -> Int:
    if list.len() == 0:
        return 0
    mut result := list[0]
    mut i := 1
    while i < list.len():
        if list[i] < result:
            result = list[i]
        i = i + 1
    return result

# Returns the maximum value, or 0 for empty list
pub fn max_val(list: List[Int]) -> Int:
    if list.len() == 0:
        return 0
    mut result := list[0]
    mut i := 1
    while i < list.len():
        if list[i] > result:
            result = list[i]
        i = i + 1
    return result

# Returns true if list is sorted in ascending order
pub fn is_sorted(list: List[Int]) -> Bool:
    mut i := 1
    while i < list.len():
        if list[i] < list[i - 1]:
            return false
        i = i + 1
    return true

# Returns the number of elements equal to value
pub fn count(list: List[Int], value: Int) -> Int:
    mut result := 0
    mut i := 0
    while i < list.len():
        if list[i] == value:
            result = result + 1
        i = i + 1
    return result
