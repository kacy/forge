# std.math — math constants
#
# Builtins (always available, no import needed):
#   abs, min, max, clamp, pow, sqrt, floor, ceil, round
#   sin, cos, tan, asin, acos, atan, atan2
#   math_log, math_log10, math_log2, math_exp, math_abs_float
#   fmt_float
#
# This module provides constants:
#   from std.math import PI, E, TAU

pub fn PI() -> Float:
    return acos(0.0 - 1.0)

pub fn E() -> Float:
    return math_exp(1.0)

pub fn TAU() -> Float:
    return acos(0.0 - 1.0) * 2.0
