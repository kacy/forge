import std.net.http as http
import std.net.tls as tls

CERT_PATH := "tests/live/fixtures/localhost.crt"
KEY_PATH := "tests/live/fixtures/localhost.key"
CA_PATH := "tests/live/fixtures/localhost-ca.crt"

fn choose_port(start: Int) -> Int!:
    mut port := start
    while port < start + 200:
        probe := tcp_listen("127.0.0.1", port)
        if probe.is_ok:
            tcp_close(probe.ok)
            return port
        port = port + 1
    fail "no free tcp port"

fn run_server(port: Int) -> Int!:
    server_cfg := tls.server_config(CERT_PATH, KEY_PATH)!
    listener := tls.listen("127.0.0.1", port, server_cfg)!

    echo_conn := listener.accept()!
    msg := echo_conn.read(64)!
    echo_conn.write_all("echo:" + msg)!
    echo_conn.close()

    http_conn := listener.accept()!
    req := http_conn.read(2048)!
    if req.contains("GET /secure HTTP/1.1"):
        http_conn.write_all("HTTP/1.1 200 OK\r\nContent-Type: text/plain\r\nContent-Length: 12\r\nConnection: close\r\n\r\nhello secure")!
    else:
        http_conn.write_all("HTTP/1.1 400 Bad Request\r\nContent-Length: 3\r\nConnection: close\r\n\r\nbad")!
    http_conn.close()

    listener.close()
    server_cfg.close()
    return 0

fn main() -> Int!:
    port := choose_port(18942)!
    server_task := spawn run_server(port)
    sleep(200)

    client_cfg := tls.client_config_with_ca_file(CA_PATH)!
    conn := tls.dial_with_config("127.0.0.1", port, "localhost", client_cfg)!
    conn.write_all("forge")!
    print(conn.read(64)!)
    conn.close()

    res := http.https_request_port("GET", "127.0.0.1", port, "/secure").send_tls_with_config("localhost", client_cfg)!
    print(res.status.to_string())
    print(res.body_text()!)
    client_cfg.close()

    await server_task
    return 0
