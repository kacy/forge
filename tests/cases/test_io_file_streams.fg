import std.fs as fs
import std.io as io

fn main() -> Int!:
    path := "/tmp/forge_io_stream_test.txt"

    writer := fs.create(path)!
    print(io.write_all_file_stream(writer, "hello")!.to_string())
    io.file_stream_close(writer)

    appender := fs.open_append(path)!
    print(io.write_all_file_stream(appender, " world")!.to_string())
    io.file_stream_close(appender)

    reader := fs.open(path)!
    print(io.read_all_file_stream_chunked(reader, 4)!)
    io.file_stream_close(reader)

    print(fs.exists(path).to_string())

    text_path := "/tmp/forge_io_text_test.txt"
    print(io.write_file_text_chunked(text_path, "alpha", 2)!.to_string())
    print(io.append_file_text_chunked(text_path, " beta", 2)!.to_string())
    print(io.read_file_text_chunked(text_path, 3)!)
    print(fs.exists(text_path).to_string())
    return 0
