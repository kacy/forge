import std.fs as fs
import std.os as os
import std.os.path as path

fn main() -> Int!:
    print(path.clean("../alpha"))
    print(path.clean("alpha/../../gamma"))
    print(path.clean("../.."))
    print(path.clean("/../alpha"))

    print((os.which("sh") != "").to_string())
    print((os.which("definitely_missing_forge_cmd_xyz") == "").to_string())

    root := fs.make_temp_dir("forge_fs_hardening_")!
    other := fs.make_temp_dir("forge_fs_hardening_")!
    print((root != other).to_string())

    temp_file := fs.make_temp_file("forge_tmp_", ".txt")!
    print(fs.exists(temp_file).to_string())
    print(fs.size(temp_file)!.to_string())

    src := path.join(root, "src")
    nested := path.join(src, "nested")
    dst := path.join(root, "dst")
    fs.make_dirs(nested)
    fs.write(path.join(src, "root.txt"), "root")!
    fs.write(path.join(nested, "leaf.txt"), "leaf")!
    fs.copy_tree(src, dst)!
    print(fs.read(path.join(dst, "root.txt"))!)
    print(fs.read(path.join(path.join(dst, "nested"), "leaf.txt"))!)

    print(fs.info(path.join(root, "missing.txt")).is_err.to_string())

    nonempty := path.join(root, "nonempty")
    fs.make_dir(nonempty)
    fs.write(path.join(nonempty, "child.txt"), "x")!
    print(fs.remove_empty_dir(nonempty).to_string())

    print(fs.remove_tree(path.join(root, "missing_tree")).to_string())
    print(fs.remove_tree(root).to_string())
    print(fs.exists(root).to_string())
    print(fs.remove(temp_file).to_string())
    print(fs.remove_tree(other).to_string())
    return 0
