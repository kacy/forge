import std.bytes as bytes
import std.net.http as http
from std.net.http import HttpRequestBytes, HttpResponse

fn choose_port(start: Int) -> Int!:
    mut port := start
    while port < start + 200:
        probe := tcp_listen("127.0.0.1", port)
        if probe.is_ok:
            tcp_close(probe.ok)
            return port
        port = port + 1
    fail "no free tcp port"

fn app(req: HttpRequestBytes) -> HttpResponse:
    if req.path_text == "/start":
        return http.redirect_response("/final").close_connection()
    return http.text(200, "streamed final body").close_connection()

fn run_server(port: Int) -> Int!:
    server_fd := tcp_listen("127.0.0.1", port)!
    http.serve_fd(tcp_accept(server_fd)!, app)!
    http.serve_fd(tcp_accept(server_fd)!, app)!
    tcp_close(server_fd)
    return 0

fn main() -> String!:
    port := choose_port(18980)!
    server_task := spawn run_server(port)
    sleep(200)

    out := bytes.buffer()
    meta := http.get_request("127.0.0.1", port, "/start").follow_redirects(2).send_into(out.buffered_chunked(4))!

    print("status:" + meta.status.to_string())
    print("content-type:" + meta.header_value("Content-Type"))
    print("body-size:" + meta.body_size.to_string())
    print("body:" + out.bytes().to_string_utf8()!)
    await server_task
    return ""
