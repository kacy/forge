import std.io as io

fn main() -> Int!:
    buffered := io.buffered_string_reader_chunked(io.string_reader("abcdef"), 2)
    print(io.buffered_string_reader_read(buffered, 3)!)
    print(io.buffered_string_reader_read(buffered, 3)!)
    print("[" + io.buffered_string_reader_read(buffered, 3)! + "]")

    lines_data := "alpha" + chr(10) + "beta" + chr(13) + chr(10) + "gamma"
    lines := io.buffered_string_reader_chunked(io.string_reader(lines_data), 2)
    print(io.buffered_string_reader_read_line(lines)!)
    print(io.buffered_string_reader_read_line(lines)!)
    print(io.buffered_string_reader_read_line(lines)!)
    print("[" + io.buffered_string_reader_read_line(lines)! + "]")

    direct := io.buffered_string_reader(io.string_reader("xyz"))
    print(io.buffered_string_reader_read(direct, 2)!)
    print(io.buffered_string_reader_read(direct, 2)!)

    sink := io.string_buffer()
    writer := io.buffered_string_writer_chunked(sink, 4)
    print(io.buffered_string_writer_write(writer, "ab")!.to_string())
    print("[" + io.string_buffer_string(sink) + "]")
    print(io.buffered_string_writer_write(writer, "cdef")!.to_string())
    print(io.string_buffer_string(sink))
    print(io.buffered_string_writer_write(writer, "gh")!.to_string())
    print(io.buffered_string_writer_flush(writer)!.to_string())
    print(io.string_buffer_string(sink))
    print(io.buffered_string_writer_flush(writer)!.to_string())
    return 0
