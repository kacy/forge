import std.fs as fs
import std.io as io

fn main() -> Int!:
    data_path := "/tmp/forge_io_buffered_data.txt"
    line_path := "/tmp/forge_io_buffered_lines.txt"

    writer := fs.create(data_path)!
    buffered_writer := io.buffered_file_writer_chunked(writer, 4)
    print(io.buffered_file_writer_write(buffered_writer, "ab")!.to_string())
    print(io.buffered_file_writer_write(buffered_writer, "cdef")!.to_string())
    print(io.buffered_file_writer_write(buffered_writer, "gh")!.to_string())
    print(io.buffered_file_writer_flush(buffered_writer)!.to_string())
    io.file_stream_close(writer)

    reader := fs.open(data_path)!
    buffered_reader := io.buffered_file_reader_chunked(reader, 3)
    print(io.buffered_file_reader_read(buffered_reader, 3)!)
    print(io.buffered_file_reader_read(buffered_reader, 3)!)
    print("[" + io.buffered_file_reader_read(buffered_reader, 3)! + "]")
    io.file_stream_close(reader)

    line_writer := fs.create(line_path)!
    buffered_line_writer := io.buffered_file_writer_chunked(line_writer, 5)
    io.buffered_file_writer_write(buffered_line_writer, "alpha" + chr(10) + "beta")!
    io.buffered_file_writer_write(buffered_line_writer, chr(13) + chr(10) + "gamma")!
    io.buffered_file_writer_flush(buffered_line_writer)!
    io.file_stream_close(line_writer)

    line_reader := fs.open(line_path)!
    buffered_line_reader := io.buffered_file_reader_chunked(line_reader, 2)
    print(io.buffered_file_reader_read_line(buffered_line_reader)!)
    print(io.buffered_file_reader_read_line(buffered_line_reader)!)
    print(io.buffered_file_reader_read_line(buffered_line_reader)!)
    print("[" + io.buffered_file_reader_read_line(buffered_line_reader)! + "]")
    io.file_stream_close(line_reader)

    fs.remove(data_path)
    fs.remove(line_path)
    return 0
