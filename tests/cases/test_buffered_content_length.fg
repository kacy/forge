import std.io as io
import std.net.http as http

fn main() -> Int!:
    crlf := chr(13) + chr(10)
    mut request := "POST /submit HTTP/1.1" + crlf
    request = request + "Host: example.com" + crlf
    request = request + "Content-Length: 11" + crlf
    request = request + "X-Test: chunked" + crlf
    request = request + crlf
    request = request + "hello world"

    reader := io.buffered_string_reader_chunked(io.string_reader(request), 3)
    request_line := io.buffered_string_reader_read_line(reader)!
    mut raw := request_line + crlf
    mut line := io.buffered_string_reader_read_line(reader)!
    while line.len() > 0:
        raw = raw + line + crlf
        line = io.buffered_string_reader_read_line(reader)!
    raw = raw + crlf

    head_req := http.parse_request(raw)
    length_text := http.get_header(head_req, "Content-Length")
    if length_text != "":
        raw = raw + io.buffered_string_reader_read(reader, parse_int(length_text)!)!

    print(http.body(http.parse_request(raw)))
    return 0
