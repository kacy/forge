# matrix math — 2D matrix operations using flat lists
# exercises: range-for iteration, nested loops, function composition

import std.fmt as fmt

fn mat_get(data: List[Int], cols: Int, r: Int, c: Int) -> Int:
    return data[r * cols + c]

fn mat_add(a: List[Int], b: List[Int], rows: Int, cols: Int) -> List[Int]:
    mut result: List[Int] := []
    for i in 0..rows * cols:
        result.push(a[i] + b[i])
    return result

fn mat_mul(a: List[Int], b: List[Int], ar: Int, ac: Int, bc: Int) -> List[Int]:
    mut result: List[Int] := []
    for r in 0..ar:
        for c in 0..bc:
            mut sum := 0
            for k in 0..ac:
                sum = sum + mat_get(a, ac, r, k) * mat_get(b, bc, k, c)
            result.push(sum)
    return result

fn mat_transpose(data: List[Int], rows: Int, cols: Int) -> List[Int]:
    mut result: List[Int] := []
    for c in 0..cols:
        for r in 0..rows:
            result.push(mat_get(data, cols, r, c))
    return result

fn mat_trace(data: List[Int], n: Int) -> Int:
    mut sum := 0
    for i in 0..n:
        sum = sum + mat_get(data, n, i, i)
    return sum

fn main():
    a := [1, 2, 3, 4]
    b := [5, 6, 7, 8]

    print("A = " + fmt.int_grid(a, 2, 2))
    print("B = " + fmt.int_grid(b, 2, 2))

    sum := mat_add(a, b, 2, 2)
    print("A+B = " + fmt.int_grid(sum, 2, 2))

    prod := mat_mul(a, b, 2, 2, 2)
    print("A*B = " + fmt.int_grid(prod, 2, 2))

    at := mat_transpose(a, 2, 2)
    print("A^T = " + fmt.int_grid(at, 2, 2))

    print("trace(A) = {mat_trace(a, 2)}")
    print("trace(A*B) = {mat_trace(prod, 2)}")

    # 3x3 identity
    id := [1, 0, 0, 0, 1, 0, 0, 0, 1]
    print("I3 = " + fmt.int_grid(id, 3, 3))
    print("trace(I3) = {mat_trace(id, 3)}")

    # 3x2 * 2x3
    c := [1, 2, 3, 4, 5, 6]
    d := [7, 8, 9, 10, 11, 12]
    cd := mat_mul(c, d, 3, 2, 3)
    print("C*D = " + fmt.int_grid(cd, 3, 3))

    print("matrix works")
