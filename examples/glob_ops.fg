import std.fs as fs
import std.glob as glob
import std.os.path as path

fn main() -> String!:
    root := fs.make_temp_dir("forge-glob-example-")!
    src := path.join(root, "src")
    ignored := path.join(root, "target")
    fs.make_dirs(src)
    fs.make_dirs(ignored)
    fs.write(path.join(root, "main.fg"), "")!
    fs.write(path.join(src, "lib.fg"), "")!
    fs.write(path.join(ignored, "skip.fg"), "")!

    pattern := path.join(root, "**/*.fg")
    matches := glob.find(root, [pattern])!
    print("matches: {matches.len()}")
    print("main matches: {glob.matches(pattern, path.join(root, "main.fg"))}")
    print("target skipped: {(matches.len() == 2)}")
    fs.remove_tree(root)
    return ""
