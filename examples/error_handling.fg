# result types and error handling

fn divide(a: Int, b: Int) -> Int!:
    if b == 0:
        fail "division by zero"
    return a / b

# try propagation: use ! to unwrap result, propagating errors to caller
fn half_divide(a: Int, b: Int) -> Int!:
    result := divide(a, b)!
    return result / 2

fn main():
    result := divide(10, 2)
    answer := half_divide(20, 4)
    print("error handling works")
